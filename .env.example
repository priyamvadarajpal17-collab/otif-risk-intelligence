# Copy this file to `.env` (never commit `.env`) or export these as real
# shell environment variables. The AI Copilot (src/otif_risk/llm_copilot.py)
# reads them at request time. No value below is a real secret.

# Required only for live mode. Leave unset to run the Copilot entirely on
# its deterministic fallback (no network, no key, fully functional demo).
OPENAI_API_KEY=

# Documented default is gpt-5-mini (a small, cost-efficient current-generation
# OpenAI model). Override to point at any other Responses-API-compatible model.
OPENAI_MODEL=gpt-5-mini

# auto (default): try live OpenAI when OPENAI_API_KEY is set, otherwise use
#   the deterministic fallback; also falls back automatically on any live
#   API/timeout/parse/validation failure.
# live: always attempt the live API (still falls back gracefully on failure).
# fallback: always use the deterministic, no-network fallback.
OTIF_LLM_MODE=auto

# Optional: directory containing this prototype's run-*/ops-*/benchmark
# artifacts. Defaults to ./artifacts relative to the current working directory.
OTIF_ARTIFACTS_DIR=artifacts
