%% OTIF Risk Intelligence -- current architecture (single source of truth;
%% no separate "target"/prior-iteration diagram is maintained).
%% Canonical source: kept in sync with docs/architecture/diagrams.py and rendered
%% to docs/architecture/current.svg by docs/architecture/generate.py.
%%
%% A noisy digital twin feeds a 10-node mechanism Bayesian network
%% (IN_FULL_FAILURE / LATE_DELIVERY -> OTIF_MISS, matching the actual OTIF
%% definition) plus exact structural do(node=value) intervention scenarios and
%% leave-one-evidence-out attribution -- decision-support diagnostics only,
%% routed to the Causal Intelligence Studio view, never into score fusion or
%% the operational decision. A Decision Value Lab replays every feasible
%% action through the twin's own mechanics under common random numbers and
%% evaluates eight capacity-constrained policies (including an
%% evaluation-only oracle ceiling) to measure simulated policy value instead
%% of assuming a fixed effectiveness fraction. A governed production
%% lifecycle wraps all of it: production-shaped source adapters and service
%% contracts (with an offline/batch parity guarantee), a deterministic run
%% manifest (git SHA, content ID, checksums), a decision/outcome ledger with
%% an observational (non-causal) cohort report, a champion/challenger
%% promotion gate with an auditable active-model pointer and append-only
%% lifecycle events, and rolling monitoring/SLO/data-quality reporting. The
%% governance layer is strictly downstream/evaluation+audit-only: it never
%% feeds score fusion (G), the operating threshold (H), or the unified
%% intervention record (J) -- it reads from them. A read-only AI Copilot (P1)
%% sits alongside the product views: it reads the persisted intervention
%% record (J) and manifest versions (N2) to build a cited, allowlisted
%% evidence packet, then explains/drafts via live OpenAI or a deterministic
%% fallback -- it never writes back to J, G, H, or any governance node.
flowchart TB
    subgraph SIM[Noisy supply-chain digital twin]
      A1[Stable vendor, SKU, lane, DC, customer traits]
      A2[Seasonality, demand, capacity and disruption shocks]
      A3[Partial observability, missing events and measurement noise]
      A1 --> A4[Line and order lifecycle simulation]
      A2 --> A4
      A3 --> A4
      A4 --> A5[Ground-truth causes, outcomes and intervention response]
    end

    A4 --> B[Data contracts + quality report]
    B --> C1[Retrospective multi-cause derivation]
    B --> C2[Point-in-time feature snapshots]
    C1 --> C3[Cause and line-evidence truth]
    C2 --> D[Rolling-origin train / validation / test]

    D --> E1[XGBoost order-risk model]
    E1 --> E2[Calibration + SHAP]
    D --> F1[10-node mechanism Bayesian network: IN_FULL_FAILURE / LATE_DELIVERY -> OTIF_MISS]
    F1 --> F2[Exact posterior, mechanism split and evidence attribution]
    F1 --> F3[Exact structural do-operator intervention scenarios]

    E1 --> G[Validated score fusion]
    F2 --> G
    G --> H[Capacity-aware operating threshold]

    C3 --> I1[Affected-SKU evidence]
    E2 --> I2[Order explanation]
    F2 --> I2
    H --> I3[Resource-aware intervention policy]
    I1 --> J[Unified intervention record]
    I2 --> J
    I3 --> J

    J --> K1[Order desk]
    J --> K2[Portfolio and hotspot views]
    J --> K3[Causal Intelligence Studio: mechanism graph, attribution, scenarios]
    F3 -.->|decision-support only, never feeds G or H| K3

    subgraph LOOP[Local operating-loop simulation]
      L1[Daily open-order scoring] --> L2[Orders close]
      L2 --> L3[Actual outcomes and derived causes]
      L3 --> L4[Feedback + drift + performance]
      L4 -->|scheduled or triggered| L5[Versioned retraining]
      L5 --> L1
    end
    J --> L1

    subgraph LAB[Decision Value Lab -- evaluation-only, never feeds G/H/J]
      M1[Heterogeneous action-response twin] --> M2[8-policy capacity-constrained evaluation]
      M2 --> M3[Oracle regret + counterfactual action ranking]
    end
    A5 -.->|evaluation-only common random numbers| M1
    I3 -.->|deployed policy under evaluation| M2
    F3 -.->|model-scenario vs. simulator-evaluation| M3

    subgraph GOV[Governed production lifecycle]
      N1[Source adapters: ERP / WMS / TMS / SRM + service contracts]
      N2[Deterministic run manifest: git SHA + content ID + checksums]
      N3[Decision + outcome ledger, idempotent]
      N4[Champion/challenger promotion gate]
      N5[Rolling monitoring + SLO + data quality]
      N6[Active-model pointer + append-only lifecycle events]
    end
    B -.->|production-shaped source boundary| N1
    N1 -.->|offline/batch parity-tested| D
    J --> N3
    N1 --> N3
    L5 -->|challenger training| N4
    M2 -->|policy value at 50% capacity| N4
    N2 -->|manifest verification| N4
    N4 --> N6
    N3 --> N5
    N5 --> N6
    N6 --> K5[Governance view]
    N4 --> K5
    N3 --> K5
    N5 --> K5
    M2 --> K4[Policy value view]
    M3 --> K4

    J -.->|persisted decision/evidence, read-only| P1[AI Copilot: cited explain/draft, live OpenAI or deterministic fallback]
    N2 -.->|model/policy/manifest versions| P1
    K5 -.-> P1
